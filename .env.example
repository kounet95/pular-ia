# ─────────────────────────────────────────────────────────────────────────────
# PULAR IA — Configuration
# 1. Copie ce fichier : cp .env.example .env
# 2. Remplis tes identifiants
# 3. Ne commite JAMAIS le fichier .env sur Git !
# ─────────────────────────────────────────────────────────────────────────────

# ── Web App ───────────────────────────────────────────────────────────────────
WEBAPP_PORT=8080

# Modèle Whisper : tiny (rapide, moins précis) | base | small | medium
WHISPER_MODEL_BOT=tiny

# ── Telegram — Scraper (optionnel) ───────────────────────────────────────────
# Obtenir sur https://my.telegram.org → "API development tools"
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# ── Telegram — Bot communautaire (optionnel) ──────────────────────────────────
# Obtenir via @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# ── Production (Railway / Render / VPS) ──────────────────────────────────────
# URL publique de l'app (sans slash final)
# PUBLIC_URL=https://pular-ia.railway.app

# Clé admin pour les endpoints /api/admin/* (export corpus, génération dataset)
# Génère une clé aléatoire : python -c "import secrets; print(secrets.token_hex(32))"
# Laisser vide = pas de protection (OK pour test local, DANGEREUX en prod)
ADMIN_KEY=
